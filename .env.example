# Surfr Website — environment variables
#
# Copy to .env.local for local development (gitignored).
# In production, set these in the Vercel project settings under
# Settings → Environment Variables.

# Surfr backend API access token. Server-side only.
# Used by app/api/leaderboard/* route handlers to authenticate with
# https://api.thesurfr.app. NEVER expose this client-side.
# Get the token from the Surfr Development Team.
SURFR_API_TOKEN=

# Optional: override the Surfr API base URL (defaults to api.thesurfr.app).
# Use a staging URL when testing against a non-production backend.
# SURFR_API_BASE_URL=https://api.thesurfr.app
